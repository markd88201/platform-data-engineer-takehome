{
  "policy_name": "restricted-job-cluster-policy",
  "definition": {
    "autotermination_minutes": {
      "type": "fixed",
      "value": 15
    },
    "spark_version": {
      "type": "fixed",
      "value": "13.3.x-scala2.12"
    },
    "node_type_id": {
      "type": "allowlist",
      "values": ["m5.xlarge", "i3.xlarge"]
    },
    "num_workers": {
      "type": "range",
      "maxValue": 4
    },
    "instance_pool_id": {
      "type": "required"
    },
    "spark_conf.spark.databricks.cluster.profile": {
      "type": "fixed",
      "value": "serverless"
    }
  }
}